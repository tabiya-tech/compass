# Example environment variables for the k6 stress test.
# Copy this file to `.env` (gitignored) and fill in the values — `./run.sh`
# will load it and forward the vars to `k6 run` via -e flags.
# If you prefer the raw CLI, k6 does NOT auto-load .env; pass each var
# yourself with `k6 run -e KEY=value ... stress-chat-flow.js`.

# ---- Required ----

# Root URL of the backend under test. No trailing slash.
# Examples:
#   http://localhost:8080
#   https://backend.dev.example.com
BASE_URL=http://localhost:8080

# Firebase Web API key for the target environment.
# Same value as the frontend uses (see frontend-new/src/envService.ts).
FIREBASE_API_KEY=AIzaSy...

# A valid invitation code of type LOGIN for the target backend.
# Enforced at backend/app/users/validators.py:20-32 — anonymous users MUST
# supply one, even when GLOBAL_DISABLE_REGISTRATION_CODE=True (that flag only
# bypasses the check for registered users).
INVITATION_CODE=xxxxxx

# Firebase anonymous signup endpoint.
# Usually: https://identitytoolkit.googleapis.com/v1/accounts:signUp
FIREBASE_SIGNUP_URL=https://identitytoolkit.googleapis.com/v1/accounts:signUp

# Client ID sent to POST /users/preferences.
# Use a stable UUID-ish value representing the calling client/app instance.
CLIENT_ID=k6s-loadtest-client

# User-AI service URL that returns the next user message for each turn.
# Expected response body to include one of: message | user_message | next_message | text
USER_AI_SERVICE_URL=http://localhost:9000/next-message

# ---- Optional ----

# Ramp profile to use. One of: smoke | baseline | stress | spike.
# Default: stress
STAGES_PROFILE=stress

# Peak number of virtual users. Overrides the profile's built-in default.
# Defaults: smoke=1, baseline=5, stress=100, spike=100.
# VUSERS=200

# Total test duration (k6 format: e.g. 10m, 5m30s, 90s).
# Overrides the profile's built-in default duration.
# Defaults: smoke=35s, baseline=3m, stress=6m, spike=2m10s.
# DURATION=10m

# Language passed in the user preferences payload. Default: en
LANGUAGE=en

# Max chat messages sent per VU iteration before stopping the conversation.
# Default: 6 for stress-chat-flow.js / 20 for e2e_chat.
MAX_MESSAGES_PER_VU=6

# Max turns for e2e_skills_elicitation_chat.
# The loop continues while !conversation_completed and turn < MAX_TURNS.
MAX_TURNS=12

# Optional prompt passed through to USER_AI_SERVICE_URL.
USER_AI_PROMPT=Simulate a realistic user in a Compass skills elicitation conversation.

# Optional user-AI timeout (k6 duration format).
USER_AI_TIMEOUT=30s

# Optional sleep between turns (seconds).
CHAT_SLEEP_SECONDS=0

# ---- e2e_chat mode only ----

# Gemini API key used to simulate the user during e2e_chat runs.
# Obtain from https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy...

# ---- Test mode selector ----

# Which test script to run. One of: smoke_test | read_apis | e2e_chat
# Leave unset (or pass as first arg to run.sh) to use the default stress-chat-flow.js.
# TEST_MODE=smoke_test
