###################
#iac/auth
###################
GCP_OAUTH_CLIENT_ID=<GCP_OAUTH_CLIENT_ID>
GCP_OAUTH_CLIENT_SECRET=<GCP_OAUTH_CLIENT_SECRET>

###################
# Backend
###################
# Taxonomy databse settings
TAXONOMY_MONGODB_URI=<MONGODB_URI>
TAXONOMY_DATABASE_NAME=<DATABASE_NAME>
TAXONOMY_MODEL_ID=<MODEL_ID>

# Application database settings
APPLICATION_MONGODB_URI=<MONGODB_URI>
APPLICATION_DATABASE_NAME=<DATABASE_NAME>

# Metrics settings
METRICS_MONGODB_URI=<MONGODB_URI>
METRICS_DATABASE_NAME=<DATABASE_NAME>
BACKEND_ENABLE_METRICS=<True/False>

# Users database settings
USERDATA_MONGODB_URI=<URI_TO_MONGODB>
USERDATA_DATABASE_NAME=<DATABASE_NAME>

# Career Explorer database settings
CAREER_EXPLORER_MONGODB_URI=<URI_TO_MONGODB>
CAREER_EXPLORER_DATABASE_NAME=<DATABASE_NAME>

# Zambia jobs database settings
JOBS_MONGODB_URI=<MONGODB_URI>
JOBS_DATABASE_NAME=<DATABASE_NAME>
JOBS_COLLECTION_NAME=<COLLECTION_NAME>

# Google Cloud Platform settings
VERTEX_API_EMBEDDINGS_REGION=<REGIONAL_LOCATION>
VERTEX_API_GEN_AI_REGION=<REGIONAL_LOCATION_OR_GLOBAL>
# Currently only supports google-vertex-ai
EMBEDDINGS_SERVICE_NAME=GOOGLE-VERTEX-AI
EMBEDDINGS_MODEL_NAME=<EMBEDDINGS_MODEL_NAME>

# Career Explorer unified config (optional JSON: sectors, country)
# Example: {"sectors":[{"name":"Agriculture","description":"...","file":"agriculture.md"}],"country":"Zambia"}
CAREER_EXPLORER_CONFIG=<JSON_OBJECT>

# Sentry settings
BACKEND_SENTRY_DSN=<BACKEND_SENTRY_DSN>
BACKEND_ENABLE_SENTRY=<True/False>

# Country settings
DEFAULT_COUNTRY_OF_USER=Unspecified

###################
# Frontend
###################

# Metrics settings
FRONTEND_ENABLE_METRICS=<True/False>

# Sentry settings
FRONTEND_SENTRY_DSN=<FRONTEND_SENTRY_DSN>
FRONTEND_ENABLE_SENTRY=<True/False>
FRONTEND_SENTRY_CONFIG=<JSON_STRING>

# PII settings
SENSITIVE_PERSONAL_DATA_RSA_ENCRYPTION_KEY=<PUBLIC_KEY_PEM_FORMAT>
SENSITIVE_PERSONAL_DATA_RSA_ENCRYPTION_KEY_ID=<KEY_ID>

# Invitation codes
FRONTEND_LOGIN_CODE=<LOGIN_CODE>
FRONTEND_REGISTRATION_CODE=<REGISTRATION_CODE>
GLOBAL_DISABLE_LOGIN_CODE=<True/False>
GLOBAL_DISABLE_REGISTRATION_CODE=<True/False>
FRONTEND_DISABLE_REGISTRATION=<True/False>
FRONTEND_DISABLE_SOCIAL_AUTH=<True/False>

# Branding settings
GLOBAL_PRODUCT_NAME=<Product-Name>
FRONTEND_BROWSER_TAB_TITLE=<Browser-Tab-Title>
FRONTEND_META_DESCRIPTION=<Meta-Description>
FRONTEND_LOGO_URL=<Logo-URL>
FRONTEND_FAVICON_URL=<Favicon-URL>
FRONTEND_APP_ICON_URL=<App-Icon-URL>
FRONTEND_THEME_CSS_VARIABLES=<JSON_STRING>
FRONTEND_SEO=<JSON_STRING>

# Skills report output settings
FRONTEND_SKILLS_REPORT_OUTPUT_CONFIG=<JSON_STRING>


# Sensitive data fields
FRONTEND_SENSITIVE_DATA_FIELDS=<JSON_STRING>
