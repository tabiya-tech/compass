    },
    "assets": {
      "logo": "/njila_logo.svg",
      "favicon": "/njila_logo.svg",
      "appIcon": "/njila_logo.svg"
    },
    "theme": {
      "brand-primary": "10 92 74",
      "brand-primary-light": "232 244 240",
      "brand-primary-dark": "10 92 74",
      "brand-primary-contrast-text": "255 255 255",
      "brand-secondary": "232 160 32",
      "brand-secondary-light": "254 246 228",
      "brand-secondary-dark": "230 142 22",
      "brand-secondary-contrast-text": "255 255 255",
      "text-primary": "26 18 8",
      "text-secondary": "125 116 105",
      "text-accent": "92 191 191"
    }
