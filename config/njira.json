        "show": true
      },
      "experienceDetails": {
        "title": true,
        "summary": true,
        "location": true,
        "dateRange": true,
        "companyName": true
      }
    }
  },
  "i18n": {
    "ui": {
      "defaultLocale": "en-US",
      "supportedLocales": [
        "en-US",
        "en-GB",
        "ny-ZM"
      ]
    },
    "conversation": {
      "default_locale": "en-US",
      "available_locales": [
        {
          "locale": "en-US",
          "date_format": "YYYY/MM/DD"
        }
      ]
    }
  },
  "faq": {
